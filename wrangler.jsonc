{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "castposter",
  "compatibility_date": "2026-04-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./src/worker.ts"
}
