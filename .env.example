# Base ERC-721 contract that exposes mintTo(address to, string tokenURI)
# Deploy/set this in Vercel to enable live CastMint wallet transactions.
VITE_CASTMINT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: change if your contract mint function has the same signature but a different name.
VITE_CASTMINT_FUNCTION_NAME=mintTo
